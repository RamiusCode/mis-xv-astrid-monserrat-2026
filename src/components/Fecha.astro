---
// FechaEvento.astro
---

<section class="px-4 pt-10 relative overflow-hidden">
  <div class="max-w-2xl mx-auto text-center">
    <!-- 🎨 IMAGEN SEPARADOR - Centro Superior -->
    <div id="separador-imagen" class="flex justify-center mb-4 z-10">
      <img
        src="/imagenes/separador2.png"
        alt="Separador decorativo"
        class="w-24 h-24 sm:w-40 sm:h-40 md:w-48 md:h-48 object-contain"
      />
    </div>

    <!-- Texto "Acompáñanos este día tan especial" -->
    <div class="mb-4" id="texto-invitacion-container">
      <div
        class="flex items-center justify-center gap-4 sm:gap-6 md:gap-8 px-4"
      >
        <!-- TEXTO CENTRAL -->
        <div id="texto-invitacion" class="flex-shrink-0">
          <p
            class="font-charm text-2xl sm:text-3xl md:text-4xl text-[#8E9198] italic leading-relaxed text-center"
          >
            Acompáñanos este día<br />tan especial
          </p>
        </div>
      </div>
    </div>

    <!-- Fecha con líneas arriba y abajo -->
    <div class="relative max-w-md mx-auto" id="fecha-evento">
      <div class="flex items-center justify-center gap-4 md:gap-6">
        <!-- SÁBADO con líneas arriba y abajo - ANCHO FIJO -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#8E9198] mb-2"></div>
          <span
            class="font-charm text-xl md:text-lg text-[#85abbf] uppercase tracking-wider font-bold text-center"
            >SÁBADO</span
          >
          <div class="w-full h-px bg-[#8E9198] mt-2"></div>
        </div>

        <!-- Número 14 - CENTRADO -->
        <div
          class="flex items-center justify-center min-w-[80px] md:min-w-[100px]"
        >
          <span
            class="font-charm text-7xl md:text-8xl text-[#8E9198] font-bold -ml-1"
            >14</span
          >
        </div>

        <!-- MARZO con líneas arriba y abajo - ANCHO FIJO -->
        <div class="flex flex-col items-center w-24 md:w-28">
          <div class="w-full h-px bg-[#8E9198] mb-2"></div>
          <span
            class="font-charm text-xl md:text-lg text-[#85abbf] uppercase tracking-wider font-bold text-center"
            >MARZO</span
          >
          <div class="w-full h-px bg-[#8E9198] mt-2"></div>
        </div>
      </div>

      <!-- Año - MOVIDO CON TRANSLATE -->
      <div class="mt-2 flex justify-center" id="anio-evento">
        <p
          class="font-charm text-3xl md:text-4xl text-[#85abbf] font-bold -translate-x-2"
        >
          2026
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("🎨 Iniciando animaciones con separador...");

      // 🎯 ESTADO INICIAL - Todo oculto con movimiento vertical
      gsap.set("#separador-imagen", { opacity: 0, y: -30 });
      gsap.set("#texto-invitacion", { opacity: 0, y: 30 });
      gsap.set("#fecha-evento", { opacity: 0, y: 30 });
      gsap.set("#anio-evento", { opacity: 0, y: 30 });

      // ✨ SCROLL TRIGGER con entrada y salida
      ScrollTrigger.create({
        trigger: "#texto-invitacion-container",
        start: "top 100%", // Cuando toca el borde inferior de la ventana
        end: "top 20%", // Desaparece cuando llega al 20% superior

        onEnter: () => {
          console.log("🎨 Componente apareciendo...");
          animarEntrada();
        },

        onLeaveBack: () => {
          console.log("🎨 Componente desapareciendo...");
          animarSalida();
        },
      });

      // 📥 ANIMACIÓN DE ENTRADA (TODO AL MISMO TIEMPO)
      function animarEntrada() {
        const tl = gsap.timeline();

        // SEPARADOR SUPERIOR (viene desde arriba)
        tl.to("#separador-imagen", {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
        })
          // TEXTO - AL MISMO TIEMPO (viene desde abajo)
          .to(
            "#texto-invitacion",
            {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: "power2.out",
            },
            "<",
          ) // ← Simultáneo
          // FECHA - AL MISMO TIEMPO (viene desde abajo)
          .to(
            "#fecha-evento",
            {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: "power2.out",
            },
            "<",
          ) // ← Simultáneo
          // AÑO - AL MISMO TIEMPO (viene desde abajo)
          .to(
            "#anio-evento",
            {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: "power2.out",
            },
            "<",
          ); // ← Simultáneo

        // 🎨 FLOTADO SUAVE DEL SEPARADOR
        gsap.to("#separador-imagen", {
          y: -8,
          duration: 3.5,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          delay: 0.8,
        });
      }

      // 📤 ANIMACIÓN DE SALIDA (secuencial, de abajo hacia arriba)
      function animarSalida() {
        const tl = gsap.timeline();

        // Contenido desaparece primero (hacia abajo)
        tl.to("#anio-evento", {
          opacity: 0,
          y: 30,
          duration: 0.4,
          ease: "power2.in",
        })
          .to(
            "#fecha-evento",
            {
              opacity: 0,
              y: 30,
              duration: 0.4,
              ease: "power2.in",
            },
            "-=0.3",
          )
          .to(
            "#texto-invitacion",
            {
              opacity: 0,
              y: 30,
              duration: 0.4,
              ease: "power2.in",
            },
            "-=0.3",
          )
          // Separador desaparece al final (hacia arriba)
          .to(
            "#separador-imagen",
            {
              opacity: 0,
              y: -30,
              duration: 0.4,
              ease: "power2.in",
            },
            "-=0.3",
          );
      }

      console.log("🎉 Animaciones con separador listas!");
    });
  }
</script>

<style>
  /* Evitar scroll horizontal */
  section {
    position: relative;
    overflow-x: hidden;
    min-height: 400px;
  }
</style>
